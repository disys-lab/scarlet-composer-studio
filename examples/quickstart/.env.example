# ─── Scarlet Composer Studio — quickstart .env ─────────────────────────────
# Copy this file to .env and fill in the values before running docker compose up.

# ─── Redis (Scarlets API backbone) ──────────────────────────────────────────
# Use your Redis instance or set REDIS_HOST=host.docker.internal if you
# bring up Redis locally (see docs/quickstart.md for a one-liner).
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_AUTH_TOKEN=your_redis_password_here

# ─── Scarlet Composer image version ─────────────────────────────────────────
SCARLET_VERSION=0.5.0

# ─── Campaign / bus configuration ───────────────────────────────────────────
# HEAD_BUS controls which global coordination bus workers subscribe to.
# Leave unset (default) for isolated campaigns.
# Set explicitly only for a shared-head deployment (Pattern B):
#   HEAD_BUS=common_headagent
#
# HEAD_BUS=

# ─── LLM endpoint (for AI agent examples) ───────────────────────────────────
# Populate these when connecting agents to a language model via LiteLLM proxy
# or a direct vLLM endpoint.
LLM_BASE_URL=
LLM_API_KEY=
MODEL_NAME=
